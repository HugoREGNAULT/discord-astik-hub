# =============================================================================
# .env.example — copy to .env (which is gitignored) and fill in real values.
# Do NOT commit real secrets. This file lists every env var the code reads.
# =============================================================================

# --- Node / runtime ---------------------------------------------------------
NODE_ENV=development

# --- Lovable Cloud / Supabase (server-only, never expose to client) ---------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=                       # publishable (anon) key — server-side reads
SUPABASE_SERVICE_ROLE_KEY=                      # SECRET — bypasses RLS, server-only
DATABASE_URL=                                   # postgres connection string (for migrations / tools)

# --- Supabase (client-exposed VITE_*) ---------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=                  # publishable (anon) key — bundled into the client

# --- Sessions (cookies signées + chiffrées HMAC + AES-GCM) ------------------
SESSION_SECRET=                                 # 32+ random bytes (base64 ou hex)

# --- Discord OAuth2 + Bot API -----------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=                              # token du bot (lecture des rôles)

# --- Discord — salons de logs (IDs de salon) --------------------------------
# Optionnel : surcharge l'ID par défaut défini dans src/lib/discord/constants.ts.
DISCORD_LOG_CHANNEL_ERROR=                      # salon de logs "error"

# --- Discord — salons de notifications fonctionnelles (IDs de salon) --------
# Optionnel : surcharge NOTIFY_CHANNELS dans constants.ts (vide = notif silencieuse).
DISCORD_NOTIFY_CHANNEL_RECRUIT=                 # salon recrutement : nouvelles candidatures
DISCORD_NOTIFY_CHANNEL_STAFF=                   # salon staff : warnings + actions sensibles + audit

# --- Bot interne (API key partagée bot <-> backend) -------------------------
BOT_API_KEY=                                    # auth des endpoints internes appelés par le bot / cron

# --- Lovable AI Gateway -----------------------------------------------------
LOVABLE_API_KEY=                                # clé du gateway AI (managed par Lovable)

# --- Paladium API -----------------------------------------------------------
PALADIUM_API_KEY=

# --- Stripe (optionnel, si paiements activés) -------------------------------
STRIPE_SECRET_KEY=
